{% extends "base.twig" %}

{% block content %}
<div class="max-w-4xl mx-auto">
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-3xl font-bold">Your Music Library</h1>
        <a href="add_song.php" class="bg-green-600 text-white px-4 py-2 rounded-md hover:bg-green-700">Add New Song</a>
    </div>

    <!-- Search Filters -->
     <div class="bg-white p-6 rounded-lg shadow-sm mb-8 border border-gray-100">
         <h3 class="font-semibold mb-4">Search & Filter</h3>
         <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
             <input type="text" id="search-title" placeholder="Song Title..." class="border p-2 rounded-md">
             <input type="text" id="search-genre" placeholder="Genre..." class="border p-2 rounded-md">
             <input type="number" id="search-year" placeholder="Year..." class="border p-2 rounded-md">
             <button id="clear-filters" class="text-gray-500 hover:text-indigo-600 text-sm">Clear Filters</button>
         </div>
     </div>

    <!-- Songs Table -->
    <div class="bg-white rounded-lg shadow overflow-hidden" id="songs-container">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Artist</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Genre</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Year</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Popularity</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200" id="songs-list">
                {% for song in songs %}
                <tr>
                    <td class="px-6 py-4 whitespace-nowrap">{{ song.title }}</td>
                    <td class="px-6 py-4 whitespace-nowrap">{{ song.artist }}</td>
                    <td class="px-6 py-4 whitespace-nowrap">{{ song.genre }}</td>
                    <td class="px-6 py-4 whitespace-nowrap">{{ song.release_year }}</td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-indigo-100 text-indigo-800">
                            {{ song.popularity_score }}/10
                        </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                        <a href="edit_song.php?id={{ song.id }}" class="text-indigo-600 hover:text-indigo-900 mr-3">Edit</a>
                        <a href="delete_song.php?id={{ song.id }}" class="text-red-600 hover:text-red-900" onclick="return confirm('Are you sure?')">Delete</a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="px-6 py-4 text-center text-gray-500">No songs found. Start adding some!</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

 <script>
 $(document).ready(function() {
     function filterSongs() {
         const title = $('#search-title').val();
         const genre = $('#search-genre').val();
         const year = $('#search-year').val();
 
         $.ajax({
             url: 'search.php',
             type: 'GET',
             data: { title, genre, year },
             success: function(data) {
                 $('#songs-list').html(data);
             }
         });
     }
 
     $('#search-title, #search-genre, #search-year').on('keyup change', filterSongs);
     
     $('#clear-filters').click(function() {
         $('input').val('');
         filterSongs();
     });
 });
 </script>
{% endblock %}
